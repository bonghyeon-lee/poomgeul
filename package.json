{
  "name": "poomgeul",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source translation platform — AI draft + community review. Phase 1: en→ko arXiv papers.",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": "24.x",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/*\" run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@next/eslint-plugin-next": "15.5.15",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  }
}

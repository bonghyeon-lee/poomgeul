{
  "name": "poomgeul",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source translation platform — AI draft + community review. Phase 1: en→ko arXiv papers.",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": "24.x",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/*\" run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "typescript": "5.7.3"
  }
}

# Postgres
DATABASE_URL=postgres://poomgeul:poomgeul@localhost:5432/poomgeul
POSTGRES_DB=poomgeul
POSTGRES_USER=poomgeul
POSTGRES_PASSWORD=poomgeul

# API
PORT=3000
SESSION_SECRET=change-me-in-production

# GitHub OAuth (M0) — see docs/guides/authentication.md
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional — defaults are fine for local dev:
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
# WEB_BASE_URL=http://localhost:3001

# LLM (ADR-0002)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
LLM_PRIMARY_MODEL=google/gemini-2.5-flash
LLM_BUDGET_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_MID_MODEL=anthropic/claude-sonnet-4-6

# External metadata (polite pools)
ARXIV_USER_AGENT=poomgeul/0.0.0 (https://poomgeul.org)
CROSSREF_MAILTO=noreply@poomgeul.org

# Observability
LOG_LEVEL=info
